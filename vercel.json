{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [],
  "functions": {
    "api/mail-worker.js": {
      "maxDuration": 60
    },
    "api/lesson-announcement.js": {
      "maxDuration": 60
    },
    "api/starter-mail-worker.js": {
      "maxDuration": 60
    },
    "api/welcome-mail.js": {
      "maxDuration": 60
    },
    "api/email-click.js": {
      "maxDuration": 10
    },
    "api/pair-streak-nudge.js": {
      "maxDuration": 60
    },
    "api/streak-event.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/starter-mail-worker",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/mail-worker",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/mail-worker",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/mail-worker",
      "schedule": "0 14 * * *"
    }
  ]
}
