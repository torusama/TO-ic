{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [],
  "functions": {
    "api/mail-worker.js": {
      "maxDuration": 60
    },
    "api/starter-mail-worker.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/starter-mail-worker",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/mail-worker",
      "schedule": "0 11 * * *"
    }
  ]
}
