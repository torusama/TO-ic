rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedCourseEmail() {
      return request.auth != null
        && request.auth.token.email in [
          "2454112132tuyen@ou.edu.vn",
          "doyouknow.nis@gmail.com",
          "nguyentrthnhquynh2801@gmail.com",
          "nttthao006@gmail.com",
          "vtanfit001@gmail.com"
        ];
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /notifications/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /activities/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /history/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /completedLessons/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /timerProgress/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /emailDeliveries/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    match /courses/{courseId} {
      allow read: if isAllowedCourseEmail();
      allow write: if false;

      match /lessons/{lessonId} {
        allow read: if isAllowedCourseEmail();
        allow write: if false;
      }
    }

    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
